{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: FastAPI + SocketIO",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:sio_app",
                "--reload"
            ],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
